# Protocol to auto-launch without confirmation.
PROTOCOL="iina"

# Jellyfin origins to allow auto-launch from (per-origin).
ORIGINS=(
  "http://jellyfin.example.com:8096"
)

# Uncomment the browsers you use (bundle ID : display name).
BROWSERS=(
  "com.google.Chrome:Chrome"
